#!/bin/bash
set -e  # Exit on any error

usage() {
    echo "Usage: $0 [-t] [-c]"
    echo "  -t: Build test files"
    echo "  -c: Enable code coverage"
    exit 1
}

OUTPUT_DIR="${OUTPUT_DIR:-"$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/tests/output_logs"}"
mkdir -p "$OUTPUT_DIR"

ENABLE_COVERAGE=0
BUILD_DIR="build_main"

while getopts ":tc" opt; do
    case $opt in
        t) 
            BUILD_TESTS=1
            BUILD_DIR="build_test"
            ;;
        c) 
            ENABLE_COVERAGE=1
            ;;
        \?) 
            usage
            ;;
    esac
done

PARENT_DIR="$(pwd)/.."
COVERAGE_DIR="$PARENT_DIR/coverage"

if [[ $ENABLE_COVERAGE -eq 1 ]]; then
    CMAKE_ARGS="$CMAKE_ARGS -DCMAKE_BUILD_TYPE=Debug -DENABLE_COVERAGE=ON"
fi

if [[ $VERBOSE -eq 1 ]]; then
    ctest --verbose
else
    ctest --output-on-failure
fi

if [ -f Testing/Temporary/LastTest.log ]; then
    cp Testing/Temporary/LastTest.log "$OUTPUT_DIR/"
    echo "Saved test logs to $OUTPUT_DIR"
else
    echo "Warning: LastTest.log not found"
fi
